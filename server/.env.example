# ==============================
# NOTA Speaks — Server Config
# ==============================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/notaspeaks?retryWrites=true&w=majority

# JWT (change this to a long random string in production!)
JWT_SECRET=nota_speaks_jwt_secret_change_this_in_production_2025

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# ==============================
# Email (Nodemailer via Gmail)
# ==============================
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Go to: Google Account → Security → App Passwords
# 3. Generate an App Password for "Mail"
# 4. Use that 16-character password below (NOT your regular Gmail password)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password

# ==============================
# Initial Admin Account (for seed.js)
# ==============================
ADMIN_EMAIL=admin@notaspeaks.org
ADMIN_PASSWORD=NOTASpeaks@2025
